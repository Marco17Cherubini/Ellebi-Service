{
    "env": {
        "browser": true,
        "es2021": true,
        "node": true
    },
    "extends": [
        "eslint:recommended"
    ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "rules": {
        "indent": [
            "error",
            2
        ],
        "linebreak-style": [
            "error",
            "windows"
        ],
        "quotes": [
            "error",
            "single",
            {
                "avoidEscape": true
            }
        ],
        "semi": [
            "error",
            "always"
        ],
        "no-unused-vars": [
            "warn",
            {
                "argsIgnorePattern": "^_"
            }
        ],
        "no-console": "off",
        "eqeqeq": [
            "error",
            "always"
        ],
        "curly": [
            "error",
            "all"
        ],
        "brace-style": [
            "error",
            "1tbs"
        ],
        "comma-dangle": [
            "error",
            "never"
        ],
        "no-multiple-empty-lines": [
            "error",
            {
                "max": 2,
                "maxEOF": 1
            }
        ],
        "no-trailing-spaces": "error",
        "space-before-function-paren": [
            "error",
            {
                "anonymous": "always",
                "named": "never",
                "asyncArrow": "always"
            }
        ]
    },
    "globals": {
        "apiRequest": "writable",
        "showSuccessMessage": "readonly",
        "showErrorMessage": "readonly",
        "formatDateDisplay": "writable",
        "getCurrentUser": "readonly",
        "redirectToLogin": "readonly",
        "Modal": "writable",
        "currentWeekStart": "writable",
        "allBookings": "writable",
        "allUsers": "writable",
        "allHolidays": "writable",
        "selectedSlot": "writable",
        "selectedBooking": "writable",
        "holidayMode": "writable",
        "selectedHolidaySlots": "writable",
        "extraWorkMode": "writable",
        "currentAssignDepositId": "writable",
        "extraWorkHoursTotal": "writable",
        "selectedExtraWorkSlots": "writable",
        "bookingModal": "writable",
        "detailModal": "writable",
        "deleteConfirmModal": "writable",
        "isDragging": "writable",
        "dragStartCell": "writable",
        "dragMode": "writable",
        "isDraggingBooking": "writable",
        "draggedBooking": "writable",
        "dragGhostElement": "writable",
        "longPressTimer": "writable",
        "touchStartX": "writable",
        "touchStartY": "writable",
        "timeSlotsWeekday": "writable",
        "timeSlotsSaturday": "writable",
        "allTimeSlots": "writable",
        "allServices": "writable",
        "workDays": "writable",
        "getTimeSlotsForDate": "writable",
        "getMonday": "writable",
        "formatDate": "writable",
        "formatDateStringDisplay": "writable",
        "Chart": "writable"
    }
}